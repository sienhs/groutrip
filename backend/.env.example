# JWT (JWT_SECRET은 최소 32바이트 랜덤 값으로 교체)
JWT_SECRET=replace-with-a-random-secret-at-least-32-bytes
JWT_ACCESS_EXP=1800000
JWT_REFRESH_EXP=604800000

# Database
DB_URL=jdbc:postgresql://localhost:5432/enjoy_trip
DB_USER=enjoy_trip_user
DB_PASS=replace-with-a-local-database-password
JPA_DDL_AUTO=create
JPA_SHOW_SQL=true

# Server / CORS
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173

# MinIO (unused until file upload is enabled)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=enjoy-trip-files

# Google Maps
GOOGLE_MAPS_API_KEY=

# Kakao Mobility
KAKAO_MOBILITY_API_KEY=

# TourAPI
TOURAPI_SERVICE_KEY=
