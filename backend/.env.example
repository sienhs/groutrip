# Database
DB_URL=jdbc:postgresql://localhost:5432/enjoy_trip
DB_USER=enjoy_trip_user
DB_PASS=change-me

# JWT (use at least 32 random bytes)
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-bytes

# OAuth2 applications
# Redirect URIs:
# Google: http://localhost:8080/login/oauth2/code/google
# Kakao:  http://localhost:8080/login/oauth2/code/kakao
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
KAKAO_OAUTH_CLIENT_ID=
KAKAO_OAUTH_CLIENT_SECRET=

# 리뷰 AI 요약(Gemini) — Google AI Studio(https://aistudio.google.com/apikey)에서 무료 발급.
# 미설정 시 리뷰 요약 기능만 비활성화되고 나머지는 정상 동작한다.
GEMINI_API_KEY=
# 선택: 모델 변경(기본 gemini-2.5-flash). 코드에서 thinking은 끔(요약용).
GEMINI_MODEL=gemini-2.5-flash

# Public URLs
FRONTEND_BASE_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
REFRESH_COOKIE_SECURE=false
