# ============================================================
# 로컬 개발용 환경 변수 예시
# 복사해서 .env.local 을 만들고 실제 값으로 채운다.
#   cp .env.local.example .env.local
# .env.local 은 절대 커밋하지 않는다(.gitignore 처리됨).
# 사용법: 백엔드 실행 전 `source .env.local`(Git Bash) 등으로 환경변수로 로드.
# (자세한 내용은 docs/local-development.md 참고)
# ============================================================

# --- Local Database ---
# DB_NAME/DB_USER/DB_PASS 는 docker-compose.db.yml(로컬 PostgreSQL)에서도 사용한다.
DB_HOST=localhost
DB_NAME=enjoy_trip
DB_URL=jdbc:postgresql://localhost:5432/enjoy_trip
DB_USER=enjoy_trip_user
DB_PASS=change-me-local-db-password
JPA_DDL_AUTO=validate

# --- Server ---
SERVER_PORT=8080

# --- Local Frontend (CORS / OAuth 리다이렉트 base) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_BASE_URL=http://localhost:5173

# --- JWT ---
JWT_SECRET=change-me-at-least-32-bytes-random-secret
JWT_ACCESS_EXP=1800000
JWT_REFRESH_EXP=604800000

# --- S3 (이미지/파일 저장) ---
# [옵션 A] 실제 AWS S3: 버킷이 이미 존재하고 IAM에 s3:PutObject/GetObject 권한이 있어야 한다.
# [옵션 B] 로컬 MinIO(추천, AWS 불필요): docker-compose.minio.yml 실행 + 아래 AWS_S3_ENDPOINT 설정.
#          이때 ACCESS/SECRET은 MinIO 로그인 계정이 되고, 버킷은 앱이 자동 생성한다.
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET_NAME=enjoy-trip-files
AWS_ACCESS_KEY_ID=change-me-access-key
AWS_SECRET_ACCESS_KEY=change-me-secret-key
# 로컬 MinIO를 쓸 때만 주석 해제(실제 AWS S3면 비워둔다)
# AWS_S3_ENDPOINT=http://localhost:9000

# 로컬은 HTTP라 Refresh 쿠키 전송 허용을 위해 false
REFRESH_COOKIE_SECURE=false

# ------------------------------------------------------------
# (선택) 로그인/외부 기능을 로컬에서 실제로 쓰려면 채운다.
# 이 앱은 SNS(OAuth) 전용 로그인이라, 로컬에서 로그인하려면
# 아래 Google/Kakao 중 최소 하나는 실제 값이 필요하다.
# 미설정 시 백엔드는 기동되지만 소셜 로그인은 동작하지 않는다.
# ------------------------------------------------------------
# GOOGLE_OAUTH_CLIENT_ID=change-me
# GOOGLE_OAUTH_CLIENT_SECRET=change-me
# KAKAO_OAUTH_CLIENT_ID=change-me
# KAKAO_OAUTH_CLIENT_SECRET=change-me

# (선택) 외부 API — 장소 검색/길찾기/추천을 로컬에서 쓰려면 채운다.
# GOOGLE_MAPS_API_KEY=change-me
# KAKAO_MOBILITY_API_KEY=change-me
# TOURAPI_SERVICE_KEY=change-me

# (선택) 로컬에서 Swagger UI 보고 싶으면 true
# SWAGGER_ENABLED=true
