# ============================================================
# EC2 Docker Compose 배포용 환경 변수 예시
# 실제 값으로 채운 .env 파일을 만들어 사용한다. (.env 는 절대 커밋 금지)
# ⚠️ 이 파일에는 절대 실제 키/시크릿을 넣지 말 것 — 항상 플레이스홀더만 유지한다.
# ============================================================

# --- Database (PostgreSQL) ---
DB_NAME=enjoy_trip
DB_USER=enjoy_trip_user
DB_PASS=change-me-strong-db-password
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false

# --- Server ---
SERVER_PORT=8080
# HTTPS(Nginx 리버스 프록시) 운영 프로필. application-prod.yml 적용:
#   forward-headers-strategy=framework(OAuth baseUrl을 https://api.도메인 으로 복원),
#   secure 쿠키, swagger off. docker-compose.backend.yml 에서 기본 prod 로 주입된다.
SPRING_PROFILES_ACTIVE=prod

# --- CORS / Frontend ---
# 프론트는 Vercel(HTTPS)에서 서빙되며 백엔드(api.도메인)와는 다른 사이트다.
# Vercel Origin을 명시한다. (여러 개면 콤마로 구분: https://a.vercel.app,https://b.vercel.app)
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
# OAuth 로그인 성공 후 리다이렉트할 프론트 base URL (Vercel).
FRONTEND_BASE_URL=https://your-frontend.vercel.app

# --- JWT ---
# ⚠️ 운영에서는 반드시 `openssl rand -base64 32` 등으로 새로 생성해 교체한다.
JWT_SECRET=replace-with-base64-32byte-random-secret
JWT_ACCESS_EXP=1800000
JWT_REFRESH_EXP=604800000
# HTTPS 적용 후 true (Secure 쿠키). SameSite=None 사용 시 Secure=true가 필수다.
REFRESH_COOKIE_SECURE=true
# 프론트(Vercel)와 백엔드(api 도메인)가 교차 사이트이므로 reissue 요청에 쿠키를 실으려면 None.
# 단일 Origin(로컬/단일 Nginx) 배포로 되돌리면 Lax 로 바꾼다.
REFRESH_COOKIE_SAME_SITE=None

# --- AWS S3 (이미지/파일 저장, backend 컨테이너에만 전달) ---
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET_NAME=your-s3-bucket-name
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# --- OAuth2 (SNS 로그인) ---
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
KAKAO_OAUTH_CLIENT_ID=your-kakao-rest-api-key
KAKAO_OAUTH_CLIENT_SECRET=your-kakao-oauth-client-secret

# --- 외부 API ---
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
KAKAO_MOBILITY_API_KEY=your-kakao-rest-api-key
TOURAPI_SERVICE_KEY=your-tourapi-service-key

# --- Swagger ---
SWAGGER_ENABLED=false
