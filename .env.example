# ============================================================
# EC2 Docker Compose 배포용 환경 변수 예시
# 실제 값으로 채운 .env 파일을 만들어 사용한다. (.env 는 절대 커밋 금지)
# ============================================================

# --- Database (PostgreSQL) ---
DB_NAME=enjoy_trip
DB_USER=enjoy_trip_user
DB_PASS=강한_DB_비밀번호
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false

# --- Server ---
SERVER_PORT=8080

# --- CORS / Frontend ---
# frontend(Nginx)와 같은 Origin으로 서빙되므로 EC2 퍼블릭 IP(또는 도메인)를 넣는다.
CORS_ALLOWED_ORIGINS=http://EC2_PUBLIC_IP
FRONTEND_BASE_URL=http://EC2_PUBLIC_IP

# --- JWT ---
JWT_SECRET=최소_32바이트_랜덤_문자열
JWT_ACCESS_EXP=1800000
JWT_REFRESH_EXP=604800000
# HTTPS 적용 전까지 false (HTTP에서 Refresh 쿠키 전송 허용)
REFRESH_COOKIE_SECURE=false

# --- AWS S3 (이미지/파일 저장, backend 컨테이너에만 전달) ---
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET_NAME=너의_S3_버킷_이름
AWS_ACCESS_KEY_ID=발급받은_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=발급받은_SECRET_KEY

# --- OAuth2 (SNS 로그인) ---
GOOGLE_OAUTH_CLIENT_ID=disabled
GOOGLE_OAUTH_CLIENT_SECRET=disabled
KAKAO_OAUTH_CLIENT_ID=disabled
KAKAO_OAUTH_CLIENT_SECRET=disabled

# --- 외부 API ---
GOOGLE_MAPS_API_KEY=
KAKAO_MOBILITY_API_KEY=
TOURAPI_SERVICE_KEY=

# --- Swagger ---
SWAGGER_ENABLED=false
