# 프론트 로컬 개발용 환경 변수 예시
# 복사해서 frontend/.env.local 을 만든다.
#   cp frontend/.env.local.example frontend/.env.local
# frontend/.env.local 은 커밋하지 않는다(.gitignore 처리됨).

# 로컬 백엔드 주소
VITE_API_BASE_URL=http://localhost:8080

# 일정 지도(Kakao Maps JS SDK)용 JavaScript 키. 카카오 개발자 콘솔의 "JavaScript 키".
# 플랫폼>Web 사이트 도메인에 http://localhost:5173 등록 필요.
VITE_KAKAO_MAP_KEY=
