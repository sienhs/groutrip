# 프로덕션(Vercel) 빌드용 환경 변수
#
# 프론트는 Vercel(HTTPS), 백엔드는 별도 도메인(https://api.example.com)으로 분리되어 있다.
# 따라서 axios base URL은 백엔드 API 도메인을 가리켜야 한다.
#
# ⚠️ Vercel 대시보드에 같은 값을 Environment Variables(Production)로 넣으면 그게 최종 소스다.
#    Project Settings → Environment Variables → VITE_API_BASE_URL = https://api.grutrip.shop → Redeploy
VITE_API_BASE_URL=https://api.grutrip.shop
