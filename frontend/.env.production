# 프로덕션(Vercel) 빌드용 환경 변수
#
# 프론트는 Vercel(HTTPS), 백엔드는 별도 도메인(https://api.example.com)으로 분리되어 있다.
# 따라서 axios base URL은 백엔드 API 도메인을 가리켜야 한다.
#
# ⚠️ 실제 값은 Vercel 대시보드의 Environment Variables(Production)가 최종 소스다.
#    Project Settings → Environment Variables → VITE_API_BASE_URL = https://api.example.com → Redeploy
#    아래 값은 본인 실제 API 서브도메인으로 교체한다.
VITE_API_BASE_URL=https://api.example.com
